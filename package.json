{
  "name": "branchmaster-repo",
  "private": true,
  "workspaces": [
    "desktop-app",
    "website",
    "breakdown-website"
  ],
  "scripts": {
    "dev": "scripts/dev.sh",
    "dev:desktop": "npm run dev --workspace desktop-app",
    "build:desktop": "npm run build --workspace desktop-app",
    "dist:mac": "npm run dist:mac --workspace desktop-app",
    "test:desktop": "npm run test --workspace desktop-app",
    "dev:website": "npm run dev --workspace website",
    "build:website": "npm run build --workspace website",
    "dev:breakdown-website": "npm run dev --workspace breakdown-website",
    "build:breakdown-website": "npm run build --workspace breakdown-website",
    "test:breakdown-website": "npm run test --workspace breakdown-website",
    "build": "npm run build:desktop && npm run build:website && npm run build:breakdown-website",
    "format": "prettier --write ."
  }
}
