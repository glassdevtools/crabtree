{
  "name": "crabtree",
  "version": "0.1.42",
  "private": true,
  "author": "Glass Devtools, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/glassdevtools/crabtree.git"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "icons:mac": "scripts/generate_macos_icons.sh",
    "postinstall": "node scripts/fix_node_pty_spawn_helper.cjs",
    "dist:mac": "scripts/package_macos.sh",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.cjs --win",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && tsc -p tsconfig.test.json && node --test .test-out/tests/*.test.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.11.0",
    "posthog-js": "^1.372.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "simple-git": "^3.36.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "prettier": "^3.7.4",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  }
}
